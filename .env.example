# JWT Secret (REQUIRED - generate a strong random string)
JWT_SECRET=your_jwt_secret_here

# MongoDB (REQUIRED)
MONGO_URI=mongodb+srv://your_mongo_uri_here

# Server
PORT=5000

# Firebase Admin SDK (REQUIRED)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# Cloudinary (REQUIRED for image uploads)
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Razorpay (REQUIRED for payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# SendGrid (REQUIRED for emails)
SENDGRID_API_KEY=your_sendgrid_api_key

# Groq AI (OPTIONAL - for smart search)
GROQ_API_KEY=your_groq_api_key

# Admin Credentials (REQUIRED - for admin dashboard)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_strong_admin_password
ADMIN_ALTERNATE_EMAIL=alternate@example.com
